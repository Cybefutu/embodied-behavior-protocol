{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oebp.dev/schemas/0.1/context-snapshot.schema.json",
  "title": "OEBP ContextSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "version", "kind", "metadata", "spec"],
  "properties": {
    "protocol": {"const": "oebp"},
    "version": {"type": "string", "pattern": "^0\\.1\\.[0-9]+$"},
    "kind": {"const": "ContextSnapshot"},
    "metadata": {"$ref": "#/$defs/metadata"},
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_id", "observed_at", "entities", "relations", "facts"],
      "properties": {
        "snapshot_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "observed_at": {"type": "string", "format": "date-time"},
        "robot_ref": {"type": "string", "maxLength": 128},
        "frame": {"type": "string", "maxLength": 128},
        "entities": {
          "type": "array",
          "items": {"$ref": "#/$defs/entity"},
          "minItems": 1,
          "maxItems": 1024
        },
        "relations": {
          "type": "array",
          "items": {"$ref": "#/$defs/relation"},
          "maxItems": 4096
        },
        "facts": {
          "type": "array",
          "items": {"$ref": "#/$defs/fact"},
          "maxItems": 4096
        }
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 128},
        "revision": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "created_at": {"type": "string", "format": "date-time"}
      }
    },
    "jsonValue": {
      "oneOf": [
        {"type": "string"},
        {"type": "number"},
        {"type": "boolean"},
        {"type": "object", "maxProperties": 64},
        {"type": "array", "maxItems": 64},
        {"type": "null"}
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "timestamp"],
      "properties": {
        "source": {"type": "string", "minLength": 1, "maxLength": 128},
        "timestamp": {"type": "string", "format": "date-time"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "freshness_ms": {"type": "integer", "minimum": 0, "maximum": 86400000},
        "trace_ref": {"type": "string", "maxLength": 128}
      }
    },
    "pose": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frame", "position", "orientation"],
      "properties": {
        "frame": {"type": "string", "minLength": 1, "maxLength": 128},
        "position": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x_m", "y_m", "z_m"],
          "properties": {
            "x_m": {"type": "number"},
            "y_m": {"type": "number"},
            "z_m": {"type": "number"}
          }
        },
        "orientation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "z", "w"],
          "properties": {
            "x": {"type": "number"},
            "y": {"type": "number"},
            "z": {"type": "number"},
            "w": {"type": "number"}
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 128},
        "type": {"type": "string", "minLength": 1, "maxLength": 128},
        "display_name": {"type": "string", "maxLength": 256},
        "pose": {"$ref": "#/$defs/pose"},
        "properties": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/jsonValue"},
          "maxProperties": 128
        },
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}, "maxItems": 32}
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["predicate", "subject"],
      "properties": {
        "predicate": {"type": "string", "minLength": 1, "maxLength": 128},
        "subject": {"type": "string", "minLength": 1, "maxLength": 128},
        "object": {"type": "string", "maxLength": 128},
        "value": {"$ref": "#/$defs/jsonValue"},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}, "maxItems": 32}
      }
    },
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "subject", "value"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "maxLength": 128},
        "subject": {"type": "string", "minLength": 1, "maxLength": 128},
        "value": {"$ref": "#/$defs/jsonValue"},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}, "maxItems": 32}
      }
    }
  }
}
