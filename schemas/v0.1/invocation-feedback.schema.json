{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oebp.dev/schemas/0.1/invocation-feedback.schema.json",
  "title": "OEBP InvocationFeedback",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "version", "kind", "metadata", "spec"],
  "properties": {
    "protocol": {"const": "oebp"},
    "version": {"type": "string", "pattern": "^0\\.1\\.[0-9]+$"},
    "kind": {"const": "InvocationFeedback"},
    "metadata": {"$ref": "#/$defs/metadata"},
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["invocation_id", "sequence", "emitted_at", "state"],
      "properties": {
        "invocation_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "sequence": {"type": "integer", "minimum": 0},
        "emitted_at": {"type": "string", "format": "date-time"},
        "state": {"enum": ["accepted", "running", "canceling", "recovering"]},
        "current_node_id": {"type": "string", "maxLength": 128},
        "progress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ratio": {"type": "number", "minimum": 0, "maximum": 1},
            "message": {"type": "string", "maxLength": 512}
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": {"type": "number"},
          "maxProperties": 64
        },
        "trace_span_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "maxLength": 128},
          "maxItems": 128
        }
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 128},
        "revision": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "created_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}
