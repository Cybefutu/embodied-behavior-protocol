{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oebp.dev/schemas/0.1/predicate-expression.schema.json",
  "title": "OEBP PredicateExpression",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "version", "kind", "metadata", "spec"],
  "properties": {
    "protocol": {"const": "oebp"},
    "version": {"type": "string", "pattern": "^0\\.1\\.[0-9]+$"},
    "kind": {"const": "PredicateExpression"},
    "metadata": {"$ref": "#/$defs/metadata"},
    "spec": {"$ref": "#/$defs/expression"}
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 128},
        "revision": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "created_at": {"type": "string", "format": "date-time"}
      }
    },
    "jsonValue": {
      "oneOf": [
        {"type": "string"},
        {"type": "number"},
        {"type": "boolean"},
        {"type": "object", "maxProperties": 64},
        {"type": "array", "maxItems": 64},
        {"type": "null"}
      ]
    },
    "expression": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "args"],
          "properties": {
            "op": {"enum": ["all", "any"]},
            "args": {
              "type": "array",
              "items": {"$ref": "#/$defs/expression"},
              "minItems": 1,
              "maxItems": 32
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "arg"],
          "properties": {
            "op": {"const": "not"},
            "arg": {"$ref": "#/$defs/expression"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "name", "subject"],
          "properties": {
            "op": {"const": "predicate"},
            "name": {"type": "string", "minLength": 1, "maxLength": 128},
            "subject": {"type": "string", "minLength": 1, "maxLength": 128},
            "object": {"type": "string", "minLength": 1, "maxLength": 128},
            "value": {"$ref": "#/$defs/jsonValue"},
            "confidence": {"type": "number", "minimum": 0, "maximum": 1},
            "freshness_ms": {"type": "integer", "minimum": 0, "maximum": 86400000}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "path"],
          "properties": {
            "op": {"const": "exists"},
            "path": {"type": "string", "minLength": 1, "maxLength": 512}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op", "left", "operator", "right"],
          "properties": {
            "op": {"const": "compare"},
            "left": {"type": "string", "minLength": 1, "maxLength": 512},
            "operator": {"enum": ["eq", "ne", "lt", "lte", "gt", "gte", "contains", "in"]},
            "right": {"$ref": "#/$defs/jsonValue"}
          }
        }
      ]
    }
  }
}
